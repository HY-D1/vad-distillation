# Git LFS configuration for VAD Distillation project
# Track model checkpoints with LFS (binary files)
*.pt filter=lfs diff=lfs merge=lfs -text
*.pth filter=lfs diff=lfs merge=lfs -text
*.ckpt filter=lfs diff=lfs merge=lfs -text
# Track prediction files with LFS (large binary)
*.npz filter=lfs diff=lfs merge=lfs -text
# Track dataset archives with LFS
*.tar.bz2 filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
# Note: Small text files (JSON, CSV, YAML) are NOT tracked with LFS
# They remain in regular git for diff visibility
