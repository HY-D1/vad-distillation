*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual environments
venv/
.env
.venv

# Data and outputs (large files)
data/torgo_raw/
data/*.csv
*.wav
*.flac
*.npy
*.pt
*.pth
*.ckpt

# Manifests and cached outputs
manifests/*.csv
splits/*.json
teacher_probs/
teacher_hard_labels/
cached_features/

# Allow markdown documentation
*.md
!README.md
!CROSS_PLATFORM_WORKFLOW.md
AGENTS.md
local/
logs/
wandb/
checkpoints/
*.bz2

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/

# Archives (large data files)
*.zip

# Platform-specific scripts (Windows)
scripts/*.ps1
scripts/*.bat
scripts/platform/windows/*.ps1
scripts/platform/windows/*.bat

# Duplicate/old analysis directories
analysis/comparison/
outputs/pilot/frame_probs/
teacher_probs_fixed/

# =============================================================================
# Training outputs - selectively tracked for cross-device workflow
# Large binary files are handled by Git LFS (see .gitattributes)
# =============================================================================

# Ignore all outputs by default
outputs/*
!outputs/.gitkeep

# Allow production_cuda summaries and checkpoints (tracked via LFS)
!outputs/production_cuda/
outputs/production_cuda/logs/*.npz
outputs/production_cuda/archive/

# Allow small text files (logs, summaries, configs) globally
!outputs/**/*.json
!outputs/**/*.csv
!outputs/**/*.yaml
!outputs/**/*.txt
!outputs/**/*.md
!outputs/**/*.log

# Keep these ignored (too large or temporary)
outputs/**/wandb/
outputs/**/tmp/
outputs/**/temp/
outputs/**/cache/
outputs/**/__pycache__/
outputs/TRAINING_STATUS.md

# Baseline outputs (can be regenerated)
outputs/baselines/*
!outputs/baselines/.gitkeep

# Archive/old outputs
outputs/archive/*
!outputs/archive/.gitkeep

# Ignore large binary checkpoint files (use LFS for these)
outputs/**/*.pt
outputs/**/*.pth
outputs/**/*.ckpt
outputs/**/*.npz
outputs/**/*.onnx
