# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/

# Virtual environments
venv/
.env
.venv

# Data and outputs (large files)
data/torgo_raw/
data/*.csv
*.wav
*.flac
*.npy
*.pt
*.pth
*.ckpt

# Manifests and cached outputs
manifests/*.csv
splits/*.json
teacher_probs/
teacher_hard_labels/
cached_features/

# =============================================================================
# ESSENTIAL FILES ONLY - Submission Ready
# Keep: README.md, LICENSE, requirements.txt, core code, configs
# Ignore: All development notes, analysis outputs, helper scripts
# =============================================================================

# Allow only essential markdown
*.md
!README.md

# Agent/AI documentation (internal use only)
AGENTS.md
docs/

# Internal documentation and notes (not for submission)
COMMIT_SUGGESTION.txt
PROJECT_STATUS.md
CLEANUP_SUMMARY.md
DEMO_CHECKLIST.md
WINDOWS_*.md
FILE_STRUCTURE_AUDIT*.md
CLI_DESIGN.md

# Analysis outputs and reports
analysis/*.json
analysis/*.txt
analysis/*.png
analysis/demo_plots/
analysis/comparison/
analysis/benchmark_*.md
analysis/verification_report*.txt

# Jupyter notebooks (for exploration only)
notebooks/*.ipynb

# Platform-specific helper scripts
scripts/**/*.sh
scripts/platform/
start.sh
start.ps1
start.bat

# Config templates and experiment matrices (not core configs)
configs/templates/
configs/week2_matrix.json
configs/*_sweep.yaml

# Output configs (generated during training)
outputs/**/config.yaml

# Utility scripts not core to the project
scripts/utils/
scripts/archive/
scripts/deprecated/
scripts/README.md
scripts/compare_methods.py  # Legacy wrapper

local/
logs/
wandb/
checkpoints/
*.bz2

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Temporary files
tmp/
temp/

# Archives (large data files)
*.zip

# Platform-specific scripts (Windows)
scripts/*.ps1
scripts/*.bat
scripts/platform/windows/*.ps1
scripts/platform/windows/*.bat

# Duplicate/old analysis directories
analysis/comparison/
outputs/pilot/frame_probs/
teacher_probs_fixed/

# =============================================================================
# Training outputs - selectively tracked for cross-device workflow
# Large binary files are handled by Git LFS (see .gitattributes)
# =============================================================================

# Ignore all outputs by default
outputs/*
!outputs/.gitkeep

# Allow production_cuda summaries and checkpoints (tracked via LFS)
!outputs/production_cuda/
outputs/production_cuda/logs/*.npz
outputs/production_cuda/archive/

# Allow small text files (logs, summaries, configs) globally
!outputs/**/*.json
!outputs/**/*.csv
!outputs/**/*.yaml
!outputs/**/*.txt
!outputs/**/*.md
!outputs/**/*.log

# Keep these ignored (too large or temporary)
outputs/**/wandb/
outputs/**/tmp/
outputs/**/temp/
outputs/**/cache/
outputs/**/__pycache__/
outputs/TRAINING_STATUS.md

# Baseline outputs (can be regenerated)
outputs/baselines/*
!outputs/baselines/.gitkeep

# Archive/old outputs
outputs/archive/*
!outputs/archive/.gitkeep

# Ignore large binary checkpoint files (use LFS for these)
outputs/**/*.pt
outputs/**/*.pth
outputs/**/*.ckpt
outputs/**/*.npz
outputs/**/*.onnx
